@using ExamMovieTracker.Models

<div class="card h-100 shadow-sm border-0 bg-dark text-white">
    
    <div class="position-relative">
        <a href="/movie/@Movie.Id">
            @if (!string.IsNullOrEmpty(Movie.PosterPath))
            {
                <img src="@($"https://image.tmdb.org/t/p/w500{Movie.PosterPath}")" class="card-img-top" alt="@Movie.Title Poster">
            }
            else
            {
                <div class="bg-secondary card-img-top d-flex align-items-center justify-content-center" style="height: 350px;">
                    <span>No Image</span>
                </div>
            }
        </a>

        <AuthorizeView>
            <Authorized>
                <button class="btn btn-dark border-0 position-absolute top-0 end-0 m-2 rounded-circle shadow"
                        style="width: 35px; height: 35px; padding: 0; display: flex; align-items: center; justify-content: center; opacity: @(IsInWatchlist ? "1" : "0.5"); transition: 0.2s;"
                        @onclick="ToggleWatchlist"
                        title="Add to Watchlist">
                    👁️
                </button>
            </Authorized>
        </AuthorizeView>
    </div>

    <div class="card-body d-flex flex-column">
        <a href="/movie/@Movie.Id" class="text-white text-decoration-none custom-link mb-2">
            <h6 class="card-title fw-bold text-warning text-truncate" title="@Movie.Title">
                🔗 @Movie.Title
            </h6>
        </a>
        
        @if (ShowCommentSection)
        {
            <div class="mb-3 p-2 bg-secondary bg-opacity-25 rounded border border-secondary border-opacity-50">
                <label class="form-label text-light mb-1" style="font-size: 0.85rem;">📝 My comment:</label>
                <textarea class="form-control form-control-sm bg-dark text-white border-secondary mb-2" 
                          rows="2" 
                          placeholder="Write your thoughts..." 
                          @bind="Movie.PersonalComment"></textarea>
                
                <button class="btn btn-outline-warning btn-sm w-100 fw-bold" @onclick="SaveComment">
                    💾 Save Comment
                </button>
            </div>
        }

        <div class="mt-auto d-flex justify-content-between align-items-center pt-2">
            <span class="badge bg-warning text-dark fs-6">⭐ @Movie.VoteAverage.ToString("0.0")</span>
            
            <AuthorizeView>
                <Authorized>
                    @if (IsFavorite)
                    {
                        <button class="btn btn-warning btn-sm fw-bold text-dark" @onclick="ToggleFavorite">
                            ⭐ Favorite
                        </button>
                    }
                    else
                    {
                        <button class="btn btn-outline-light btn-sm" @onclick="ToggleFavorite">
                            🤍 Favorite
                        </button>
                    }
                </Authorized>
            </AuthorizeView>
        </div>
    </div>
</div>

@code {
    // === LES DONNÉES ENTRANTES (Paramètres) ===
    [Parameter, EditorRequired] public Movie Movie { get; set; } = default!;
    [Parameter] public bool IsFavorite { get; set; }
    [Parameter] public bool IsInWatchlist { get; set; }
    [Parameter] public bool ShowCommentSection { get; set; } = false; // Désactivé par défaut

    // === LES ÉVÉNEMENTS SORTANTS (Pour prévenir la page parente) ===
    [Parameter] public EventCallback<Movie> OnToggleFavorite { get; set; }
    [Parameter] public EventCallback<Movie> OnToggleWatchlist { get; set; }
    [Parameter] public EventCallback OnSaveComment { get; set; }

    // Méthodes internes qui déclenchent les événements vers le parent
    private async Task ToggleFavorite() => await OnToggleFavorite.InvokeAsync(Movie);
    private async Task ToggleWatchlist() => await OnToggleWatchlist.InvokeAsync(Movie);
    private async Task SaveComment() => await OnSaveComment.InvokeAsync();
}