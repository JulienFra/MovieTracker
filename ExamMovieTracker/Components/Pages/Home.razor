@page "/"
@rendermode InteractiveServer

@using ExamMovieTracker.Models
@using ExamMovieTracker.Services
@using ExamMovieTracker.Components @* Ajoute ça si ton MovieCard est dans un dossier Shared, sinon adapte ou retire *@

@inject TmdbService TmdbService
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Home - MovieTracker</PageTitle>

<div class="text-center mt-4 mb-5">
    <h1>🍿 MovieTracker</h1>
    <p class="lead">Discover and save your favorite movies.</p>

    <div class="container mt-4">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="input-group mb-3 shadow-sm">
                    <input type="text" class="form-control" placeholder="Search for a movie..." 
                           @bind="searchTerm" @bind:event="oninput" @onkeyup="HandleKeyUp" />
                    <button class="btn btn-warning fw-bold" type="button" @onclick="SearchMovies">Search</button>
                    
                    @if (!string.IsNullOrEmpty(searchTerm))
                    {
                        <button class="btn btn-outline-secondary" type="button" @onclick="ClearSearch">X</button>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@if (movies == null)
{
    // 1. Écran de chargement
    <div class="text-center mt-5">
        <div class="spinner-border text-warning" role="status" style="width: 3rem; height: 3rem;">
            <span class="visually-hidden">Loading...</span>
        </div>
        <p class="mt-2">Fetching movies...</p>
    </div>
}
else if (!movies.Any())
{
    // 2. Aucun résultat de recherche
    <div class="alert alert-warning text-center">No movies found. Please try another search!</div>
}
else
{
    // 3. Affichage de la grille de films
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 row-cols-xl-5 g-4 mb-5">
        @foreach (var movie in movies)
        {
            // Vérification si le film actuel est dans les listes de l'utilisateur
            bool isFavorite = favorites.Any(f => f.Id == movie.Id);
            bool isInWatchlist = watchlist.Any(f => f.Id == movie.Id);

            <div class="col">
                <MovieCard Movie="movie" 
                           IsFavorite="isFavorite" 
                           IsInWatchlist="isInWatchlist" 
                           OnToggleFavorite="ToggleFavorite" 
                           OnToggleWatchlist="ToggleWatchlist" />
            </div>
        }
    </div>

    @if (!isSearching)
    {
        <div class="d-flex justify-content-center align-items-center gap-3 mt-5 mb-5">
            <button class="btn btn-warning fw-bold" @onclick="PreviousPage" disabled="@(currentPage == 1)">
                ⬅️ Previous
            </button>
            <span class="text-white fs-5">Page <strong>@currentPage</strong></span>
            <button class="btn btn-warning fw-bold" @onclick="NextPage">
                Next ➡️
            </button>
        </div>
    }
}

@code {
    // === VARIABLES GLOBALES ===
    private List<Movie>? movies;
    private string? userEmail;
    private int currentPage = 1;
    
    // Listes du LocalStorage
    private List<Movie> favorites = new List<Movie>();
    private List<Movie> watchlist = new List<Movie>();

    // Variables pour la recherche
    private string searchTerm = "";
    private bool isSearching = false;

    // === CYCLE DE VIE DU COMPOSANT ===
    protected override async Task OnInitializedAsync()
    {
        await LoadMovies();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            userEmail = authState.User.Identity?.Name;
            
            if (!string.IsNullOrEmpty(userEmail))
            {
                var favs = await LocalStorage.GetItemAsync<List<Movie>>($"favorites_{userEmail}");
                if (favs != null) favorites = favs;

                var watch = await LocalStorage.GetItemAsync<List<Movie>>($"watchlist_{userEmail}");
                if (watch != null) watchlist = watch;
            }

            StateHasChanged();
        }
    }

    // === MÉTHODES DE CHARGEMENT DE L'API ===
    private async Task LoadMovies()
    {
        isSearching = false;
        movies = null; 
        movies = await TmdbService.GetPopularMoviesAsync(currentPage);
    }

    // === MÉTHODES DE PAGINATION ===
    private async Task NextPage()
    {
        currentPage++;
        await LoadMovies();
    }

    private async Task PreviousPage()
    {
        if (currentPage > 1)
        {
            currentPage--;
            await LoadMovies();
        }
    }

    // === MÉTHODES DE RECHERCHE ===
    private async Task SearchMovies()
    {
        if (string.IsNullOrWhiteSpace(searchTerm))
        {
            currentPage = 1;
            await LoadMovies();
            return;
        }

        isSearching = true;
        movies = null; 
        movies = await TmdbService.SearchMoviesAsync(searchTerm);
    }

    private async Task ClearSearch()
    {
        searchTerm = "";
        currentPage = 1;
        await LoadMovies();
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SearchMovies();
        }
    }

    // === MÉTHODES DU LOCAL STORAGE (SAUVEGARDES) ===
    private async Task ToggleFavorite(Movie movie)
    {
        if (string.IsNullOrEmpty(userEmail)) return;

        var existingFavorite = favorites.FirstOrDefault(f => f.Id == movie.Id);
        
        if (existingFavorite != null) favorites.Remove(existingFavorite);
        else favorites.Add(movie);

        await LocalStorage.SetItemAsync($"favorites_{userEmail}", favorites);
    }

    private async Task ToggleWatchlist(Movie movie)
    {
        if (string.IsNullOrEmpty(userEmail)) return;

        var existingMovie = watchlist.FirstOrDefault(f => f.Id == movie.Id);
        
        if (existingMovie != null) watchlist.Remove(existingMovie);
        else watchlist.Add(movie);

        await LocalStorage.SetItemAsync($"watchlist_{userEmail}", watchlist);
    }
}